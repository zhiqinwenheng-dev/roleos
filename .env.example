# DEEPSEEK_API_KEY: Required for admin auto-translation endpoint.
# Keep this value only in deployment environment variables. Never expose in frontend.
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
# Optional DeepSeek base URL and model for translation.
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Optional admin panel password for /admin login.
# If omitted, default is "roleos-admin". Strongly recommended to change in production.
ADMIN_PASSWORD="CHANGE_ME"
