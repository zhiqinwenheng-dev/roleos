{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roleos.local/schemas/role.v1.json",
  "title": "RoleSpecV1",
  "type": "object",
  "required": [
    "id",
    "kind",
    "specVersion",
    "lifecycle",
    "title",
    "description",
    "updatedAt",
    "purpose",
    "inputs",
    "outputs",
    "constraints"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "role"
    },
    "specVersion": {
      "const": "v1"
    },
    "lifecycle": {
      "enum": [
        "draft",
        "validated",
        "active",
        "deprecated"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "purpose": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
