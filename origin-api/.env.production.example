PORT=3000
ROLEOS_ROOT=.
ROLEOS_STORE_PROVIDER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ROLEOS_JWT_SECRET=replace-with-strong-secret
ROLEOS_ADMIN_API_KEY=replace-with-admin-key
ROLEOS_PAYMENT_WEBHOOK_SECRET=replace-with-webhook-secret
ROLEOS_ALLOW_LEGACY_WEBHOOK_SECRET_HEADER=0
ROLEOS_DEFAULT_PLAN=starter
ROLEOS_PERSONAL_GATEWAY_BASE_URL=https://your-personal-gateway.example.com/pay
ROLEOS_PERSONAL_GATEWAY_STATUS_URL=
ROLEOS_PERSONAL_GATEWAY_API_KEY=
ROLEOS_OPENCLAW_ENDPOINT=http://localhost:4310
ROLEOS_OPENCLAW_API_KEY=
ROLEOS_OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
ROLEOS_RECONCILE_STALE_MINUTES=30
ROLEOS_RECONCILE_EXPIRE_MINUTES=1440
ROLEOS_RECONCILE_LIMIT=200
ROLEOS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
FEISHU_WEBHOOK_URL=

# Optional go-live automation settings
ROLEOS_AUTOMATION=0
ROLEOS_AUTODEPLOY_CLOUDFLARE=0
ROLEOS_BUILD_RS_BINARY=0
ROLEOS_RUN_REMOTE_SMOKE=0
ROLEOS_REMOTE_BASE_URL=https://api.roleos.ai
ORIGIN_API_URL=https://origin-api.roleos.ai
EDGE_SHARED_SECRET=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=roleos-web
CLOUDFLARE_PAGES_BRANCH=production

# Optional RS installer automation settings
ROLEOS_DEPLOY_OPENCLAW=yes
ROLEOS_MODEL_API_KEY=
ROLEOS_FEISHU_APP_ID=
ROLEOS_FEISHU_APP_SECRET=
ROLEOS_STARTER_KIT_ID=content-starter-kit
ROLEOS_FIRST_TEAM_INTENT=Generate an onboarding-ready starter output.
